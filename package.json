{
  "name": "polipadaria",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm --prefix backend start",
    "start:frontend": "npm --prefix polipadaria-frontend start",
    "install:all": "npm --prefix backend install && npm --prefix polipadaria-frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}